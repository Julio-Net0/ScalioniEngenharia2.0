# Scalioni Engenharia — variáveis de ambiente

# App
DEBUG=false
SECRET_KEY=mude-este-valor-em-producao

# Database
POSTGRES_DB=scalioni
POSTGRES_USER=scalioni
POSTGRES_PASSWORD=senha-segura
DATABASE_URL=postgresql+asyncpg://scalioni:senha-segura@postgres:5432/scalioni

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=

# MinIO (produção)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=mude-este-valor

# Traefik (produção)
DOMAIN=scalioni.com.br
ACME_EMAIL=admin@scalioni.com.br

